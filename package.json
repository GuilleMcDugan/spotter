{
  "name": "spotter",
  "productName": "SPOTTER",
  "version": "1.0.0",
  "description": "Diseño sonoro asistido por IA",
  "main": "out/main/index.js",
  "author": "Lemö Labs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "dist": "npm run build && electron-builder --mac --arm64",
    "pack": "npm run build && electron-builder --mac --arm64 --dir"
  },
  "build": {
    "appId": "studio.lemolabs.spotter",
    "productName": "SPOTTER",
    "copyright": "Copyright © 2026 Lemö Labs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/electron-store/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "SPOTTER",
      "background": null,
      "window": {
        "width": 540,
        "height": 360
      },
      "contents": [
        { "x": 140, "y": 170, "type": "file" },
        { "x": 400, "y": 170, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
